# ============================================================
# News Card Generator Pro — Environment Variables
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# ============================================================

# ---- PostgreSQL --------------------------------------------------
DATABASE_URL=postgresql://newscard:changeme@localhost:5432/newscard
POSTGRES_PASSWORD=changeme

# ---- App ---------------------------------------------------------
SESSION_SECRET=your-super-secret-session-key-min-32-chars
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
BASE_URL=http://localhost:8080
NODE_ENV=production

# ---- API Server --------------------------------------------------
PORT=8080

# ---- Telegram Bot (optional) ------------------------------------
# Get a token from @BotFather on Telegram. Leave empty to disable.
TELEGRAM_BOT_TOKEN=

# ---- Admin Accounts (seeded on first run) ----------------------
# Default admin:  admin@newscard.pro / Admin@123
# Default demo:   demo@newscard.pro  / Demo@123
# Change passwords immediately after first login!
